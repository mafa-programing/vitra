{
  "appId": "com.vitra.dryfruits",
  "appName": "Vitra",
  "webDir": "www",
  "backgroundColor": "#ece3d6",
  "android": {
    "allowMixedContent": false
  },
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 900,
      "backgroundColor": "#23201b",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#fbf6ee"
    }
  }
}
